{
  "name": "holdthegoblin",
  "version": "0.1.0",
  "description": "Evidence-gated verifier for AI coding agents.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "holdthegoblin": "./dist/src/cli.js",
    "htg": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "examples",
    "integrations",
    "docs",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "demo:db-delete": "npm run build && node examples/db-delete-block/demo.mjs",
    "verify:self": "npm run build && node dist/src/cli.js verify",
    "release:check": "npm run typecheck && npm test && npm run smoke && npm run demo:db-delete && npm run verify:self && npm pack --dry-run",
    "prepack": "npm run build",
    "dev": "npm run build && node dist/src/cli.js"
  },
  "keywords": [
    "ai-agent",
    "claude-code",
    "codex",
    "cursor",
    "warp",
    "guardrails",
    "agent-security",
    "security",
    "verifier",
    "semgrep",
    "trivy"
  ],
  "author": "etherman-os",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  }
}
