{
  "name": "holdthegoblin",
  "version": "0.1.3",
  "description": "Evidence-gated verifier for AI coding agents.",
  "type": "module",
  "packageManager": "npm@10.9.7",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/etherman-os/HoldTheGoblin.git"
  },
  "bugs": {
    "url": "https://github.com/etherman-os/HoldTheGoblin/issues"
  },
  "homepage": "https://github.com/etherman-os/HoldTheGoblin#readme",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "holdthegoblin": "./dist/src/cli.js",
    "htg": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "examples",
    "integrations",
    "docs",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "PRIVACY.md",
    "SECURITY.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test --test-concurrency=1 dist/test/*.test.js",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "package:smoke": "npm run build && node scripts/package-smoke.mjs",
    "demo:db-delete": "npm run build && node examples/db-delete-block/demo.mjs",
    "verify:self": "npm run build && node dist/src/cli.js verify",
    "release:check": "npm run typecheck && npm test && npm run smoke && npm run demo:db-delete && npm run verify:self && npm run package:smoke && npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run release:check",
    "dev": "npm run build && node dist/src/cli.js"
  },
  "keywords": [
    "ai-agent",
    "claude-code",
    "codex",
    "cursor",
    "warp",
    "guardrails",
    "agent-security",
    "security",
    "verifier",
    "semgrep",
    "trivy"
  ],
  "author": "etherman-os",
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
